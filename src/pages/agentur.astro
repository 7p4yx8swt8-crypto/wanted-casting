---
import Layout from '../layouts/Layout.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={`${t('agency.title')} — Agentur Wanted`}>
  <section class="container-wide py-20 md:py-32">
    <p class="eyebrow reveal reveal-delay-1">— Wanted / Agency</p>
    <h1 class="display-xl mt-6 max-w-[14ch] reveal reveal-delay-2">{t('agency.title')}</h1>

    <div class="mt-16 grid grid-cols-1 md:grid-cols-12 gap-10">
      <div class="md:col-span-4">
        <p class="font-display text-2xl leading-snug reveal reveal-delay-3">
          {t('agency.lead')}
        </p>
      </div>
      <div class="md:col-span-7 md:col-start-6 space-y-6 text-lg text-ink/80 leading-relaxed reveal reveal-delay-4">
        <p>{t('agency.p1')}</p>
        <p>{t('agency.p2')}</p>
        <p>{t('agency.p3')}</p>
      </div>
    </div>
  </section>

  <section class="border-y border-ink/10 bg-bone">
    <div class="container-wide py-16 grid grid-cols-2 md:grid-cols-4 gap-8">
      <div>
        <div class="font-mono text-xs text-muted mb-2">Film & Serie</div>
        <div class="font-display text-3xl">National</div>
      </div>
      <div>
        <div class="font-mono text-xs text-muted mb-2">Werbung & Foto</div>
        <div class="font-display text-3xl">International</div>
      </div>
      <div>
        <div class="font-mono text-xs text-muted mb-2">Schwerpunkt</div>
        <div class="font-display text-3xl">Berlin / BB</div>
      </div>
      <div>
        <div class="font-mono text-xs text-muted mb-2">Database</div>
        <div class="font-display text-3xl">40 000+</div>
      </div>
    </div>
  </section>
</Layout>
