---
import Layout from '../layouts/Layout.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const faqs = [
  { q: t('help.faq.1.q'), a: t('help.faq.1.a') },
  { q: t('help.faq.2.q'), a: t('help.faq.2.a') },
  { q: t('help.faq.3.q'), a: t('help.faq.3.a') },
  { q: t('help.faq.4.q'), a: t('help.faq.4.a') },
];
---

<Layout title={`${t('help.title')} — Agentur Wanted`}>
  <section class="container-wide py-20 md:py-32">
    <p class="eyebrow">— FAQ</p>
    <h1 class="display-xl mt-6 max-w-[16ch]">{t('help.title')}</h1>
    <p class="mt-8 max-w-xl text-lg text-ink/70">{t('help.lead')}</p>

    <div class="mt-20 max-w-3xl">
      {faqs.map((faq, i) => (
        <details class="group border-t border-ink/20 py-6">
          <summary class="flex items-start justify-between gap-6 cursor-pointer list-none">
            <div>
              <div class="font-mono text-xs text-muted mb-2">{String(i + 1).padStart(3, '0')}</div>
              <div class="font-display text-2xl md:text-3xl leading-snug">{faq.q}</div>
            </div>
            <div class="font-display text-3xl text-ink/40 group-open:rotate-45 transition-transform mt-2">+</div>
          </summary>
          <p class="mt-6 text-lg text-ink/70 leading-relaxed max-w-2xl">
            {faq.a}
          </p>
        </details>
      ))}
      <div class="border-t border-ink/20"></div>
    </div>
  </section>
</Layout>
