---
import Layout from '../layouts/Layout.astro';
---

<Layout title="AGB & Datenschutz — Agentur Wanted">
  <section class="container-wide py-20 md:py-32 max-w-3xl">
    <p class="eyebrow">— Legal</p>
    <h1 class="display-lg mt-6">AGB & Datenschutz</h1>

    <div class="mt-12 space-y-8 text-base leading-relaxed text-ink/80">
      <p class="text-muted">
        Hier den Text aus dem aktuellen AGB- und Datenschutz-Dokument übernehmen
        (zu finden auf <a href="https://www.wanted-casting.de/agb-dsgvo" class="underline">wanted-casting.de/agb-dsgvo</a>).
      </p>

      <div>
        <h2 class="font-display text-xl text-ink mb-3">Allgemeine Geschäftsbedingungen</h2>
        <p>[Hier den AGB-Text einfügen]</p>
      </div>

      <div>
        <h2 class="font-display text-xl text-ink mb-3">Datenschutzerklärung</h2>
        <p>[Hier den Datenschutz-Text einfügen]</p>
      </div>
    </div>
  </section>
</Layout>
