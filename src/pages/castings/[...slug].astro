---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const castings = await getCollection('castings', ({ data }) => data.active === true);
  return castings.map((casting) => ({
    params: { slug: casting.slug },
    props: { casting },
  }));
}

const { casting } = Astro.props;
const { Content } = await render(casting);
---

<Layout title={`${casting.data.title} — Agentur Wanted`}>
  <article class="container-wide py-20 md:py-32 max-w-4xl">
    <a href="/castings" class="eyebrow inline-flex items-center gap-2 hover:text-ink transition-colors">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 7H1M6 12L1 7l5-5"/></svg>
      Alle Castings
    </a>

    <p class="eyebrow mt-12">{casting.data.format_type} · {casting.data.dates}</p>
    <h1 class="display-lg mt-4">{casting.data.title}</h1>

    <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6 border-y border-ink/10 py-8">
      <div>
        <div class="eyebrow mb-2">Drehort</div>
        <div class="text-lg">{casting.data.location}</div>
      </div>
      <div>
        <div class="eyebrow mb-2">Gesucht</div>
        <div class="text-lg">{casting.data.looking_for}</div>
      </div>
      {casting.data.fee && (
        <div>
          <div class="eyebrow mb-2">Gage</div>
          <div class="text-lg">{casting.data.fee}</div>
        </div>
      )}
    </div>

    <div class="prose prose-lg max-w-2xl mt-12 text-ink/80 leading-relaxed [&>p]:mb-4 [&>h2]:font-display [&>h2]:text-2xl [&>h2]:mt-8 [&>h2]:mb-3">
      <Content />
    </div>

    {casting.data.apply_url && (
      <div class="mt-12">
        <a href={casting.data.apply_url} class="btn-primary">
          Jetzt bewerben
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 7h12M8 2l5 5-5 5"/></svg>
        </a>
      </div>
    )}
  </article>
</Layout>
