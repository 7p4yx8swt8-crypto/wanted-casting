---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const allCastings = await getCollection('castings', ({ data }) => data.active === true);
const castings = allCastings.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Aktuelle Castings — Agentur Wanted">
  <section class="container-wide py-20 md:py-32">
    <p class="eyebrow">— Open Calls</p>
    <h1 class="display-xl mt-6">Aktuelle Castings</h1>
    <p class="mt-8 max-w-xl text-lg text-ink/70">
      Diese Castings laufen aktuell. Bewerbung über das verlinkte Formular oder direkt per E-Mail.
    </p>

    {castings.length === 0 ? (
      <div class="mt-20 py-20 border-y border-ink/10 text-center">
        <p class="font-display text-2xl text-ink/60">Aktuell keine offenen Castings.</p>
        <p class="mt-4 text-sm text-muted">
          Registriere dich trotzdem in unserer Datenbank — wir melden uns, sobald etwas Passendes kommt.
        </p>
      </div>
    ) : (
      <div class="mt-20 border-t border-ink/20">
        {castings.map((casting) => (
          <a
            href={`/castings/${casting.slug}`}
            class="group block border-b border-ink/20 py-10 hover:bg-bone/40 transition-colors -mx-6 px-6"
          >
            <div class="grid grid-cols-1 md:grid-cols-12 gap-6 items-start">
              <div class="md:col-span-2">
                <div class="font-mono text-xs text-muted">{casting.data.format_type}</div>
                <div class="font-mono text-xs text-muted mt-1">{casting.data.dates}</div>
              </div>
              <div class="md:col-span-7">
                <h2 class="font-display text-2xl md:text-3xl leading-snug group-hover:text-ember transition-colors">
                  {casting.data.title}
                </h2>
                <p class="mt-3 text-sm text-ink/70 leading-relaxed">{casting.data.looking_for}</p>
              </div>
              <div class="md:col-span-3 md:text-right text-sm text-ink/60">
                <div>{casting.data.location}</div>
                {casting.data.fee && <div class="mt-1 text-muted">{casting.data.fee}</div>}
              </div>
            </div>
          </a>
        ))}
      </div>
    )}
  </section>
</Layout>
