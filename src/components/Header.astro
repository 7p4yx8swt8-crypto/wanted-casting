---
import { getLangFromUrl, useTranslations, localizedPath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const CASTCONNECT_LOGIN = 'https://online.agentur-wanted.de/de/login/actor';
const CASTCONNECT_REGISTER = 'https://online.agentur-wanted.de/de/projectrole/application/key/1e8f8e5d-75b1-0c22-4996-e6b1fb2ffc08';

const navItems = [
  { href: localizedPath('/agentur', lang), label: t('nav.agency') },
  { href: localizedPath('/castings', lang), label: t('nav.castings') },
  { href: localizedPath('/anfrage', lang), label: t('nav.request') },
  { href: localizedPath('/kontakt', lang), label: t('nav.contact') },
  { href: localizedPath('/hilfe', lang), label: t('nav.help') },
];

const otherLang = lang === 'de' ? 'en' : 'de';
const otherLangPath = lang === 'de' ? '/en' : Astro.url.pathname.replace(/^\/en/, '') || '/';
---

<header class="border-b border-ink/10 bg-paper/80 backdrop-blur-md sticky top-0 z-50">
  <div class="container-wide flex items-center justify-between py-5">
    <a href={localizedPath('/', lang)} class="flex items-baseline gap-2 group">
      <img src="/logo.png" alt="agentur wanted" class="h-32 w-auto" />
    </a>

    <nav class="hidden lg:flex items-center gap-8">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="text-sm uppercase tracking-widest text-ink/70 hover:text-ink transition-colors"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a
        href={otherLangPath}
        class="text-xs uppercase tracking-widest text-muted hover:text-ink transition-colors"
      >
        {otherLang}
      </a>
      <span class="text-ink/20 hidden sm:inline">·</span>
      <a
        href={CASTCONNECT_LOGIN}
        class="hidden sm:inline text-sm uppercase tracking-widest text-ink/70 hover:text-ink transition-colors"
      >
        {t('nav.login')}
      </a>
      <a href={CASTCONNECT_REGISTER} class="btn-primary !py-2 !px-4 text-xs">
        {t('nav.register')}
      </a>
      <button
        id="mobile-menu-toggle"
        class="lg:hidden p-2"
        aria-label="Menu"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <line x1="3" y1="8" x2="21" y2="8"/>
          <line x1="3" y1="16" x2="21" y2="16"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-ink/10 bg-paper">
    <nav class="container-wide flex flex-col py-6 gap-4">
      {navItems.map((item) => (
        <a href={item.href} class="text-base uppercase tracking-widest text-ink/80">
          {item.label}
        </a>
      ))}
      <a href={CASTCONNECT_LOGIN} class="text-base uppercase tracking-widest text-ink/80 pt-4 border-t border-ink/10">
        {t('nav.login')}
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
