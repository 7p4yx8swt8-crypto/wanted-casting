---
import { getLangFromUrl, useTranslations, localizedPath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<footer class="bg-ink text-paper mt-32">
  <div class="container-wide py-20 grid grid-cols-1 md:grid-cols-12 gap-10">
    <div class="md:col-span-5">
      <div class="font-display text-4xl tracking-tightest leading-none mb-6">
        wanted<span class="text-ember">.</span>
      </div>
      <p class="text-paper/60 text-sm leading-relaxed max-w-sm">
        {t('footer.address')}
      </p>
    </div>

    <div class="md:col-span-4 space-y-3 text-sm">
      <div class="eyebrow !text-paper/40">{t('footer.phone')}</div>
      <a href="tel:+493091449520" class="block text-paper hover:text-ember transition-colors">
        030 91 44 95 20
      </a>
      <div class="eyebrow !text-paper/40 pt-3">{t('footer.whatsapp')}</div>
      <a href="https://wa.me/491711270289" class="block text-paper hover:text-ember transition-colors">
        0171 1270289
      </a>
      <div class="eyebrow !text-paper/40 pt-3">{t('footer.email')}</div>
      <a href="mailto:info@wanted-casting.de" class="block text-paper hover:text-ember transition-colors">
        info@wanted-casting.de
      </a>
    </div>

    <div class="md:col-span-3 flex flex-col gap-3 text-sm">
      <a href={localizedPath('/impressum', lang)} class="text-paper/70 hover:text-paper transition-colors">
        {t('footer.legal')}
      </a>
      <a href={localizedPath('/agb-dsgvo', lang)} class="text-paper/70 hover:text-paper transition-colors">
        {t('footer.terms')}
      </a>
      <a href="https://www.wanted-casting.de/_files/ugd/5da671_4ad0907bebcc4c04baeb690f184339ed.pdf" class="text-paper/70 hover:text-paper transition-colors">
        {t('footer.documents')}
      </a>
      <div class="flex gap-4 mt-4">
        <a href="https://de-de.facebook.com/agenturwanted/" aria-label="Facebook" class="text-paper/60 hover:text-paper transition-colors">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M14 9h3V6h-3c-1.7 0-3 1.3-3 3v2H9v3h2v7h3v-7h2.5l.5-3H14V9z"/></svg>
        </a>
        <a href="https://www.crew-united.com/de/agentur-wanted_105656.html" aria-label="Crew United" class="text-paper/60 hover:text-paper transition-colors">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15 15 0 010 20M12 2a15 15 0 000 20"/></svg>
        </a>
      </div>
    </div>
  </div>

  <div class="border-t border-paper/10">
    <div class="container-wide py-6 text-xs text-paper/40 flex flex-col sm:flex-row justify-between gap-2">
      <span>{t('footer.copyright')}</span>
      <span>Berlin · Brandenburg · DE</span>
    </div>
  </div>
</footer>
